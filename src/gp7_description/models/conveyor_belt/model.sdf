<?xml version="1.0" ?>

<sdf version="1.4">

    <model name="conveyor_belt">

        <model name="conveyorbelt_fixed">

            <static>true</static>

            <link name="belt_visual">
                <visual name="visual">
                    <geometry>
                        <mesh>
                            <scale>0.565 0.796 0.391</scale>
                            <uri>model://conveyor_belt/meshes/conveyor_belt.dae</uri>
                        </mesh>
                    </geometry>
                </visual>
                <collision name="collision">
                    <origin xyz="0.0 0.0 0" rpy="0.0 0.0 0.0"/>
                    <geometry>
                        <mesh>
                            <scale>0.565 0.796 0.391</scale>
                            <uri>model://conveyor_belt/meshes/conveyor_belt.dae</uri>
                        </mesh>
                    </geometry>
                </collision>
            </link>

        </model>

        <model name="conveyorbelt_moving">

            <allow_auto_disable>0</allow_auto_disable>
            <static>false</static>

            <pose>0 0 0.29 0 0 0.0</pose>

            <link name="belt_moving">
                <inertial>
                    <mass>100.0</mass>
                    <inertia>
                        <ixx>0.1</ixx>
                        <ixy>0.1</ixy>
                        <ixz>0.1</ixz>
                        <iyy>0.1</iyy>
                        <iyz>0.1</iyz>
                        <izz>0.1</izz>
                    </inertia>
                </inertial>
                <collision name="belt_collision">
                    <geometry>
                        <box>
                            <size>0.24 0.955 0.001</size>
                        </box>
                    </geometry>
                    <surface>
                        <friction>
                            <ode>
                                <!-- <mu>100.0</mu> -->
                                <!-- <mu2>100.0</mu2> -->
                                <mu>2.0</mu>
                                <mu2>2.0</mu2>
                            </ode>
                            <torsional>
                                <coefficient>1000.0</coefficient>
                                <patch_radius>0.1</patch_radius>
                            </torsional>
                        </friction>
                    </surface>
                </collision>
               
            </link>

        </model>

        <joint name="belt_joint" type="prismatic">
            <parent>conveyorbelt_fixed::belt_visual</parent>
            <child>conveyorbelt_moving::belt_moving</child>
            <axis>
                <xyz>0 1 0</xyz>
                <limit>
                    <lower>0.0</lower>
                    <upper>0.01</upper>
                </limit>
            </axis>
        </joint>

        <plugin name="ros2_conveyorbelt_plugin" filename="libros2_conveyorbelt_plugin.so" >
            <ros>
                <namespace></namespace>
            </ros>
            <max_velocity>1.0</max_velocity>
            <publish_rate>1000</publish_rate>
        </plugin>

    </model>

</sdf>