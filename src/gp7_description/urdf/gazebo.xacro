<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="gp7_yaskawa_gazebo">

<!--
  Gazebo-only properties for the GP7 robot model.
  base_link is the kinematic root (no world frame, no virtual joint in URDF).
  In Gazebo, the robot is spawned at z=0.33 so base_link sits 0.33 m above the
  ground plane.  The world_to_base_joint fixed joint anchors base_link to the
  Gazebo world frame so the robot does not fall.  Controllers (arm_controller)
  operate on joint_1..joint_6 and are unaffected by this joint.
-->
<gazebo>
  <joint name="world_to_base_joint" type="fixed">
    <parent>world</parent>
    <child>base_link</child>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
</gazebo>

<gazebo reference="base_link">
  <self_collide>0</self_collide>
  <kinematic>false</kinematic>
  <gravity>true</gravity>
  <!-- mu/mu2: friction coefficients matching the table/ground (high traction) -->
  <mu>1.0</mu>
  <mu2>1.0</mu2>
</gazebo>

<gazebo reference="link_s">
  <material>Gazebo/White</material>
</gazebo>

<gazebo reference="link_l">
  <material>Gazebo/Blue</material>
</gazebo>

<gazebo reference="link_u">
  <material>Gazebo/White</material>
</gazebo>

<gazebo reference="link_r">
  <material>Gazebo/Blue</material>
</gazebo>

<gazebo reference="link_b">
  <material>Gazebo/White</material>
</gazebo>

<gazebo reference="link_t">
  <material>Gazebo/Blue</material>
</gazebo>

<gazebo reference="base_link">
  <material>Gazebo/Blue</material>
</gazebo>

</xacro:macro>

</robot>